{
    "name": "naoki-tsuchiya/ray-di-context",
    "description": "Context, meta, and compile management for Ray.Di applications with separated read-only compile dir and writable tmp dir",
    "license": "MIT",
    "authors": [
        {
            "name": "Naoki Tsuchiya"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "ray/di": "^2.19",
        "ray/compiler": "^1.14"
    },
    "require-dev": {
        "carthage-software/mago": "1.44.0",
        "phpunit/phpunit": "11.5.56"
    },
    "autoload": {
        "psr-4": {
            "NaokiTsuchiya\\RayDiContext\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NaokiTsuchiya\\RayDiContext\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "mago lint --minimum-fail-level note",
        "analyze": "mago analyze",
        "fmt": "mago fmt --check",
        "cs": ["@lint", "@fmt"],
        "sa": "@analyze",
        "tests": ["@cs", "@sa", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
